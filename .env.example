# 🌐 Configuración de Entorno para AceAutonomousCreator

# API Key de Ace Data Cloud (acedata.cloud)
ACEDATA_API_KEY=tu_clave_de_api_aqui

# Conexión a la Blockchain de Solana (Usaremos Devnet para pruebas y Mainnet para producción)
SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Clave privada del agente de Solana (Formato Base58, nunca compartas esta clave con nadie)
# IMPORTANTE: Generaremos una cuenta limpia solo para el bot, no uses tu cuenta principal
AGENT_PRIVATE_KEY=tu_clave_privada_base58_aqui

# Configuración del Gateway RPC de Synapse (OOBE Protocol)
SYNAPSE_RPC_URL=https://rpc.synapse.oobeprotocol.ai
